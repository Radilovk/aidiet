{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "WebWorker"],
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "worker.js",
    "fitness/worker.js",
    "context-compression.js",
    "analytics-compression.js",
    "json-patch.js",
    "client-card.js",
    "food-nutrition.js",
    "food-catalog.js"
  ],
  "exclude": ["node_modules", "android", "dist", ".wrangler"]
}
