{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "worker.js",
    "context-compression.js",
    "analytics-compression.js",
    "json-patch.js",
    "client-card.js"
  ],
  "exclude": ["node_modules", "android"]
}
