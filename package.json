{
  "name": "aidiet",
  "version": "1.0.0",
  "description": "AI-powered personalized nutrition planning application",
  "main": "worker.entry.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run test:worker && wrangler deploy --env production",
    "deploy:staging": "npm run test:worker && wrangler deploy --env staging",
    "build:worker": "node scripts/bundle-worker.mjs",
    "typecheck:worker": "node scripts/typecheck-worker.mjs",
    "test:worker": "node scripts/verify-worker.mjs",
    "test:plan-adequacy": "node scripts/plan-adequacy/run-offline.mjs",
    "test:plan-adequacy:live": "node scripts/plan-adequacy/run-live.mjs",
    "upload:kv": "bash KV/upload-kv-keys.sh",
    "serve": "python -m http.server 8000",
    "test": "echo \"Open test.html in browser to test the application\""
  },
  "keywords": [
    "ai",
    "diet",
    "nutrition",
    "cloudflare-workers",
    "openai",
    "gemini"
  ],
  "author": "Radilov-K",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.86.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Radilovk/aidiet.git"
  },
  "overrides": {
    "@codetrix-studio/capacitor-google-auth": {
      "@capacitor/core": "^8.3.1"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capgo/capacitor-navigation-bar": "^8.1.5",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4"
  }
}
