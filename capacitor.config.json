{
  "appId": "com.biocode.nutriplan",
  "appName": "NutriPlan",
  "webDir": "capacitor-shell",
  "server": {
    "url": "https://biocode.website",
    "androidScheme": "https"
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_nutriplan",
      "iconColor": "#009A9E",
      "sound": "default"
    },
    "GoogleAuth": {
      "_note": "serverClientId is overwritten at build time by the CI pipeline using the GOOGLE_WEB_CLIENT_ID GitHub Actions secret. On Android, strings.xml server_client_id takes precedence.",
      "scopes": [
        "profile",
        "email",
        "https://www.googleapis.com/auth/drive.appdata"
      ],
      "serverClientId": "YOUR_WEB_CLIENT_ID.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  },
  "android": {
    "minWebViewVersion": 60,
    "allowMixedContent": false,
    "backgroundColor": "#F0FDFA"
  }
}
